{
  "name": "unocss-preset-completion",
  "version": "0.3.3",
  "description": "Custom auto completion preset for UnoCSS",
  "keywords": [
    "unocss",
    "unocss-preset",
    "unocss-preset-completion",
    "unpreset"
  ],
  "homepage": "https://github.com/subframe7536/unocss-preset-completion#readme",
  "bugs": {
    "url": "https://github.com/subframe7536/unocss-preset-completion/issues"
  },
  "license": "MIT",
  "author": "subframe7536",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/subframe7536/unocss-preset-completion.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "release": "bun run build && bun run test && bumpp",
    "format": "oxfmt",
    "lint": "oxlint --fix",
    "test": "bun test"
  },
  "devDependencies": {
    "@subf/config": "^0.1.3",
    "@types/bun": "^1.3.11",
    "@unocss/core": "^66.6.8",
    "@unocss/preset-wind3": "^66.6.8",
    "@unocss/transformer-directives": "^66.6.8",
    "@unocss/transformer-variant-group": "^66.6.8",
    "bumpp": "^10.4.1",
    "oxfmt": "0.44.0",
    "oxlint": "^1.59.0",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3"
  }
}
